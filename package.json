{
  "name": "dropshipping-hub",
  "version": "0.1.0",
  "private": true,
  "description": "中国輸入 無在庫販売 ハブシステム (BASE × Alibaba / THE CKB)",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:api": "pnpm --filter @hub/api dev",
    "dev:web": "pnpm --filter @hub/web dev",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @hub/db generate"
  },
  "engines": {
    "node": ">=20"
  }
}
