# ===== AIオペレーター24 backend 環境変数 =====

# サーバ
PORT=8080
PUBLIC_API_BASE_URL=https://api.ai-operator24.com   # TwiML の action / ws url 組み立てに使用
PUBLIC_WS_BASE_URL=wss://api.ai-operator24.com

# データベース (PostgreSQL / Supabase)
DATABASE_URL=postgres://user:pass@localhost:5432/ai_operator24

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_VALIDATE_SIGNATURE=true        # 開発時は false で迂回可

# AI (OpenAI / OpenRouter どちらも可。OpenAI互換)
OPENAI_API_KEY=sk-xxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_SUMMARY_MODEL=gpt-4o-mini
# OpenRouterを使う場合（OPENAI_API_KEY に OpenRouterのキーを入れる）:
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   OPENAI_MODEL=openai/gpt-4o-mini        （または deepseek/deepseek-chat 等。JSON出力対応モデル推奨）
#   OPENAI_SUMMARY_MODEL=openai/gpt-4o-mini
OPENAI_BASE_URL=

# 通知メール (Resend)
RESEND_API_KEY=re_xxxx
MAIL_FROM=AIオペレーター24 <noreply@ai-operator24.com>
# 管理画面認証
# 本番: Supabase の JWT Secret を設定し、AUTH_DEV_MODE=false にする
SUPABASE_JWT_SECRET=
AUTH_DEV_MODE=true
# 管理画面フロントのオリジン（CORS）。本番はVercelドメインなどにDST限定
CORS_ORIGIN=*

# 原価レート（経費モニタリング用・改定時に変更）
USD_JPY=155

# 問い合わせ導線（自社販売）
LEADS_NOTIFY_EMAIL=sales@ai-operator24.com   # 新規リードの通知先
LEAD_WORKER_INTERVAL_SEC=60                   # ステップメール送信ワーカーの間隔(秒)。0で無効

# 週次サマリーの自動送信（毎週月曜）。実メール配信前提のため既定OFF。
WEEKLY_DIGEST_ENABLED=false
WEEKLY_DIGEST_HOUR_UTC=23                      # 23 UTC = 月曜 8:00(JST) に送信

# 決済（Square）。設計は docs/square-billing.md。未設定時は課金機能オフ。
SQUARE_ENV=sandbox                              # sandbox / production
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=

# デモ用フォールバック挨拶（テナント未解決時）
DEFAULT_GREETING=お電話ありがとうございます。AI受付です。ご用件をお話しください。
