# ===== AIオペレーター24 backend 環境変数 =====

# サーバ
PORT=8080
PUBLIC_API_BASE_URL=https://api.ai-operator24.com   # TwiML の action / ws url 組み立てに使用
PUBLIC_WS_BASE_URL=wss://api.ai-operator24.com

# データベース (PostgreSQL / Supabase)
DATABASE_URL=postgres://user:pass@localhost:5432/ai_operator24

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_VALIDATE_SIGNATURE=true        # 開発時は false で迂回可

# AI (MVPは OpenAI 優先)
OPENAI_API_KEY=sk-xxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_SUMMARY_MODEL=gpt-4o-mini

# 通知メール (Resend)
RESEND_API_KEY=re_xxxx
MAIL_FROM=AIオペレーター24 <noreply@ai-operator24.com>

# 管理画面認証
# 本番: Supabase の JWT Secret を設定し、AUTH_DEV_MODE=false にする
SUPABASE_JWT_SECRET=
AUTH_DEV_MODE=true
# 管理画面フロントのオリジン（CORS）。本番はVercelドメインなどにDST限定
CORS_ORIGIN=*

# 原価レート（経費モニタリング用・改定時に変更）
USD_JPY=155

# デモ用フォールバック挨拶（テナント未解決時）
DEFAULT_GREETING=お電話ありがとうございます。AI受付です。ご用件をお話しください。
