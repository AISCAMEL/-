      '記事ID', '生成日時', '媒体', 'テーマカテゴリ', '切り口',
      'タイトル/フック', '本文', 'ハッシュタグ', '文字数', '使用AIモデル',
      'ステータス', '投稿予定日', '投稿日', '担当者', '備考'
    ],

    // 媒体定義（仕様書 §2）
    platforms: {
      X: {
        name: 'X (旧Twitter)',
        maxChars: 140,
        structure: '1メッセージで完結。冒頭にフックを置き、最後にCTA。',
        hashtagCount: '2〜3個'
      },
      IG: {
        name: 'Instagram',
        maxChars: 400,
        structure: '結論→共感→CTAの順。改行を多めに入れ読みやすく。',
        hashtagCount: '8〜15個'
      },
      TT: {
        name: 'TikTok / YouTube Shorts',
        maxChars: 500,
        structure: '動画台本形式。[フック(最初の3秒)] → [本編] → [CTA] のブロックで記述。',
        hashtagCount: '3〜5個'
      },
      BLOG: {
        name: 'LINE配信 / ブログ・LP',
        maxChars: 1500,
        structure: '見出し付きの長文。検索流入を意識し、導入→本文（小見出し複数）→まとめ→CTA。',
        hashtagCount: 'なし（ハッシュタグ不要）'
      }
    },

    // テーマカテゴリ（仕様書 §3.1）
    categories: {
      T01: 'カーローン審査を通りやすくするコツ',
      T02: '自社ローン・他社で断られた方向けの対応',
      T03: '車買取・高価買取（2026年の中古車相場）',
      T04: '自社リース（頭金なし・月々払い・GPS管理）',
      T05: '個人事業主・法人向けカーローン',
      T06: '中古車選びのコツ・お役立ち情報',
      T07: 'お客様の声・成約実績の紹介',
      T08: '季節・イベント（ボーナス/決算/新生活）に絡めた提案'
    },

    // 切り口（フック）パターン（仕様書 §3.2）
    hooks: [
      '質問型（読者に問いかけて引き込む）',
      '数字型（具体的な数字で説得力を出す）',
      '失敗談型（よくある失敗から学ばせる）',
      '比較型（A vs B で違いを示す）',
      '実績型（実例・成果を示す）',
      '共感型（読者の悩みに寄り添う）',
      '緊急型（今だけ・期間限定の動機づけ）',
      'お役立ちリスト型（◯選・チェックリスト）'
    ],

    // 事業コンテキスト（プロンプトに必ず注入）
