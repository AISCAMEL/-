# OpenRouter API キー（必須）。https://openrouter.ai/keys で取得。
# 本ファイルを .env にコピーして値を設定する。.env はコミットしないこと。
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# モデルフォールバックチェーン（任意・カンマ区切り）。
# 正確なモデルIDは https://openrouter.ai/models で要確認。
OPENROUTER_MODELS=deepseek/deepseek-chat-v3-0324:free,google/gemini-2.0-flash-exp:free,anthropic/claude-3.5-haiku

# ローカルサーバー待受ポート（任意・既定3000）
PORT=3000
