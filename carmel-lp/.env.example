# OpenRouter API キー（必須）。https://openrouter.ai/keys で取得。
# 本ファイルを .env にコピーして値を設定する。.env はコミットしないこと。
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# モデルフォールバックチェーン（任意・カンマ区切り）。
# 正確なモデルIDは https://openrouter.ai/models で要確認。
OPENROUTER_MODELS=deepseek/deepseek-chat-v3-0324:free,google/gemini-2.0-flash-exp:free,anthropic/claude-3.5-haiku

# ローカルサーバー待受ポート（任意・既定3000）
PORT=3000

# ---- 会話ログ（任意） ----
# CHAT_LOG=1 のときだけ data/chat-logs/ にJSONLで保存（既定オフ）。
# CHAT_LOG=1
# CHAT_LOG_DIR=./data/chat-logs

# ---- 有人ハイブリッド対応（任意・Slack連携） ----
# 設定すると営業時間内に「担当者と話す」が有効化され、相談がSlackに届く。
# 未設定なら自動的にAI＋LINE/電話へフォールバック（LP自体は動作する）。
# SLACK_BOT_TOKEN=xoxb-xxxxxxxx          # Bot トークン（chat:write, channels:history 等）
# SLACK_CHANNEL=C0123ABCD                # 通知先チャンネルID
# BUSINESS_HOURS_START=10                # 営業開始時(時)。既定10
# BUSINESS_HOURS_END=19                  # 営業終了時(時)。既定19
# BUSINESS_TZ_OFFSET=9                   # タイムゾーン(UTCからの時差)。既定9(JST)
# BUSINESS_DAYS=0,1,2,3,4,5,6            # 営業曜日(日=0)。既定は毎日
# HANDOFF_TIMEOUT_MS=20000              # 担当者未応答とみなすまで(ms)。既定20000
