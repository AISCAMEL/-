# ===== Hub API =====
API_PORT=3001
NODE_ENV=development

# 在庫・価格の定期同期間隔（分）。0 または未設定で無効。例: 60 = 1時間ごと
SYNC_INTERVAL_MINUTES=0

# ===== Database =====
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hub?schema=public"

# ===== Redis (queue) =====
REDIS_URL="redis://localhost:6379"

# ===== BASE (販売チャネル / OAuth2.0) =====
BASE_CLIENT_ID=
BASE_CLIENT_SECRET=
BASE_REDIRECT_URI=http://localhost:3001/auth/base/callback
BASE_ACCESS_TOKEN=
BASE_REFRESH_TOKEN=

# ===== Alibaba.com Open Platform =====
ALIBABA_APP_KEY=
ALIBABA_APP_SECRET=
ALIBABA_ACCESS_TOKEN=

# ===== THE CKB =====
THECKB_API_BASE_URL=https://api.theckb.com
THECKB_API_KEY=

# ===== 市場調査: 楽天ウェブサービス (商品検索API・無料) =====
RAKUTEN_APP_ID=

# ===== 市場調査: Yahoo!ショッピング (商品検索API v3・無料) =====
YAHOO_APP_ID=

# ===== 市場調査: eBay (Browse API・越境/海外相場) =====
# client_credentials で取得した OAuth アプリトークン
EBAY_OAUTH_TOKEN=

# ===== 仕入れ: AliExpress (Open Platform / Dropshipping API) =====
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=

# ===== 市場調査: Amazon (いずれか / 要契約) =====
# Keepa (リサーチ向け・有料)
KEEPA_API_KEY=
# Amazon Product Advertising API (PA-API 5.0)
AMAZON_PAAPI_ACCESS_KEY=
AMAZON_PAAPI_SECRET_KEY=
AMAZON_PAAPI_PARTNER_TAG=

# ===== 為替レート API =====
FX_API_URL=
FX_API_KEY=

# ===== コネクタ動作モード (mock | live) =====
# 既定モード。各コネクタは「キーがあれば自動で live」になる。
CONNECTOR_MODE=mock
# 個別に強制したい場合のみ設定（例: 楽天を mock に固定）
# BASE_MODE=mock
# ALIBABA_MODE=mock
# THECKB_MODE=mock
# AMAZON_MODE=mock
# RAKUTEN_MODE=live
# → 楽天を実データにするには上の RAKUTEN_APP_ID を入れるだけ（自動 live）。
