# ===== Hub API =====
API_PORT=3001
NODE_ENV=development

# ===== Database =====
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hub?schema=public"

# ===== Redis (queue) =====
REDIS_URL="redis://localhost:6379"

# ===== BASE (販売チャネル / OAuth2.0) =====
BASE_CLIENT_ID=
BASE_CLIENT_SECRET=
BASE_REDIRECT_URI=http://localhost:3001/auth/base/callback
BASE_ACCESS_TOKEN=
BASE_REFRESH_TOKEN=

# ===== Alibaba.com Open Platform =====
ALIBABA_APP_KEY=
ALIBABA_APP_SECRET=
ALIBABA_ACCESS_TOKEN=

# ===== THE CKB =====
THECKB_API_BASE_URL=https://api.theckb.com
THECKB_API_KEY=

# ===== 為替レート API =====
FX_API_URL=
FX_API_KEY=

# ===== コネクタ動作モード (mock | live) =====
CONNECTOR_MODE=mock
