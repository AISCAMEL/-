# IWASAWA SURF BASE — 環境変数サンプル
# Supabase プロジェクト作成後、この内容を .env.local にコピーして値を入れてください。
# （.env.local は Git にコミットされません）

# Supabase ダッシュボード > Project Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...（anon public キー）

# サイトのベースURL（メール確認リンクのリダイレクト先などに使用）
NEXT_PUBLIC_SITE_URL=http://localhost:3000
